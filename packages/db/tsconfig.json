{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": ["node"],
    "declaration": true,
    "outDir": "./dist"
  },
  "include": ["src/**/*.ts", "drizzle.config.ts"],
  "exclude": ["dist", "drizzle", "node_modules"]
}
